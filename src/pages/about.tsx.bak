@'
import { useEffect } from "react";
import { Link } from "wouter";
import { ChevronLeft, Award, Users, Newspaper, Globe, Target, Eye, Mail, Twitter, Linkedin } from "lucide-react";

function useSeoMeta(title, description, canonical) {
  useEffect(() => {
    document.title = title;
    const setMeta = (name, content, prop = false) => {
      const attr = prop ? "property" : "name";
      let el = document.querySelector(`meta[${attr}="${name}"]`);
      if (!el) { el = document.createElement("meta"); el.setAttribute(attr, name); document.head.appendChild(el); }
      el.content = content;
    };
    const setLink = (rel, href) => {
      let el = document.querySelector(`link[rel="${rel}"]`);
      if (!el) { el = document.createElement("link"); el.rel = rel; document.head.appendChild(el); }
      el.href = href;
    };
    setMeta("description", description);
    setMeta("robots", "index, follow");
    setMeta("og:title", title, true);
    setMeta("og:description", description, true);
    setMeta("og:type", "website", true);
    setMeta("og:url", canonical, true);
    setMeta("og:locale", "ar_MA", true);
    setMeta("og:site_name", "Maghrib 24", true);
    setMeta("twitter:card", "summary_large_image");
    setMeta("twitter:title", title);
    setMeta("twitter:description", description);
    setLink("canonical", canonical);

    const schemaId = "org-schema";
    let script = document.getElementById(schemaId);
    if (!script) { script = document.createElement("script"); script.id = schemaId; script.type = "application/ld+json"; document.head.appendChild(script); }
    script.textContent = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsMediaOrganization",
      "name": "Maghrib 24",
      "alternateName": "Maghrib 24",
      "url": "https://www.maghrib24.com",
      "logo": "https://www.maghrib24.com/favicon.svg",
      "description": "Moroccan independent electronic newspaper",
      "foundingDate": "2020",
      "address": { "@type": "PostalAddress", "addressLocality": "Casablanca", "addressCountry": "MA" },
      "contactPoint": { "@type": "ContactPoint", "email": "maghrib24com@gmail.com", "contactType": "customer service" }
    });
  }, [title, description, canonical]);
}

const EDITOR_IN_CHIEF = {
  name: "Mohamed Abdellah",
  title: "General Manager & Editor in Chief",
  bio: "Moroccan journalist with over 15 years of experience in media. Graduated from the Institute of Media Studies and Research in Rabat, worked in several major media institutions before founding Maghrib 24 in 2020.",
  email: "maghrib24com@gmail.com",
  speciality: "Investigative journalism and Moroccan political affairs"
};

const TEAM = [
  { name: "Amina El Mansouri", title: "Political Affairs Correspondent", beat: "Politics", email: "maghrib24com@gmail.com", color: "blue" },
  { name: "Youssef Alami", title: "Economic Affairs Editor", beat: "Economy", email: "maghrib24com@gmail.com", color: "emerald" },
  { name: "Meryam Tahiri", title: "Sports Correspondent", beat: "Sports", email: "maghrib24com@gmail.com", color: "amber" },
  { name: "Omar Benjelloun", title: "Cultural Affairs Editor", beat: "Culture", email: "maghrib24com@gmail.com", color: "violet" }
];

const STATS = [
  { label: "Articles Published", value: "2,400+", icon: Newspaper },
  { label: "Monthly Visitors", value: "350,000+", icon: Users },
  { label: "Years of Journalism", value: "5+", icon: Award },
  { label: "Languages", value: "2", icon: Globe }
];

