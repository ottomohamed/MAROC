  amber: "bg-amber-100 dark:bg-amber-900/20 text-amber-700",
  violet: "bg-violet-100 dark:bg-violet-900/20 text-violet-700"
};

export default function AboutPage() {
  useSeoMeta("About Us | Maghrib 24", "Moroccan independent electronic newspaper", "https://www.maghrib24.com/about");

  return (
    <div className="min-h-screen bg-gray-50 dark:bg-zinc-950" dir="rtl">
      <div className="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav className="flex items-center gap-2 text-xs text-gray-400 mb-8 flex-row-reverse">
          <Link href="/" className="hover:text-emerald-600">Home</Link>
          <ChevronLeft className="w-3 h-3" />
          <span className="text-gray-600">About Us</span>
        </nav>

        <div className="bg-white dark:bg-zinc-900 rounded-2xl p-6 md:p-8 mb-8 text-right">
          <div className="inline-flex items-center gap-2 bg-emerald-50 rounded-full px-4 py-1.5 mb-4">
            <span className="text-xs font-bold text-emerald-700">ABOUT THE NEWSPAPER</span>
            <Newspaper className="w-3.5 h-3.5 text-emerald-600" />
          </div>
          <p className="text-gray-600 dark:text-gray-400 leading-relaxed text-base">
            Maghrib 24 is an independent Moroccan electronic newspaper dedicated to Moroccan affairs,
            defending the country's sanctities, and publishing truth and information with respect and professional integrity.
          </p>
